{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:openclaw:schema:context-projection-bundle:v1",
  "title": "Context Projection Bundle",
  "description": "单次 Context 构建的完整投影集合。包含请求 ID、投影列表、统计信息。",

  "type": "object",
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1,
      "description": "请求 ID，用于跨系统追踪"
    },
    "projected_at": {
      "type": "string",
      "format": "date-time",
      "description": "Context 构建时间"
    },
    "projections": {
      "type": "array",
      "items": {
        "$ref": "urn:openclaw:schema:context-projection:v1"
      },
      "minItems": 1,
      "maxItems": 50,
      "description": "投影列表，最少 1 条"
    },
    "projection_counts": {
      "type": "object",
      "properties": {
        "total_entries": {
          "type": "integer",
          "minimum": 1,
          "description": "投影总数"
        },
        "total_chars": {
          "type": "integer",
          "minimum": 0,
          "description": "所有投影内容总字符数"
        },
        "by_source": {
          "type": "object",
          "description": "按投影源统计条目数",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "required": ["total_entries", "total_chars", "by_source"],
      "additionalProperties": false
    }
  },
  "required": ["request_id", "projected_at", "projections", "projection_counts"],
  "additionalProperties": false
}
